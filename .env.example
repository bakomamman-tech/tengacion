# Core
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/tengacion
JWT_SECRET=change_me_jwt_secret
MEDIA_SIGNING_SECRET=change_me_media_signing_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
AUTH_CHALLENGE_SECRET=change_me_auth_challenge_secret
APP_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000,capacitor://localhost,https://localhost
VITE_API_URL=/api
VITE_GA_MEASUREMENT_ID=
VITE_GA_DEBUG_MODE=false
VITE_GIPHY_API_KEY=
VITE_CONTACT_EMAIL=stephen@tengacion.com
VITE_SUPPORT_EMAIL=stephen@tengacion.com
VITE_ADMIN_NOTIFICATION_EMAIL=stephen@tengacion.com

# Google Play / Trusted Web Activity
# Use the final Android application id and the Google Play App Signing SHA-256 fingerprint.
ANDROID_TWA_PACKAGE_NAME=com.tengacion.app
ANDROID_TWA_SHA256_CERT_FINGERPRINTS=

# Auth / email OTP (optional)
REQUIRE_EMAIL_OTP=false
CONTACT_EMAIL=stephen@tengacion.com
SUPPORT_EMAIL=stephen@tengacion.com
ADMIN_NOTIFICATION_EMAIL=stephen@tengacion.com
EMAIL_FROM=stephen@tengacion.com
EMAIL_LOGO_URL=/tengacion_logo_512.png
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
# Legacy aliases are still accepted for existing deployments.
EMAIL_USER=
EMAIL_PASS=
# Production SMTP secrets must be configured in Render environment variables, not committed to GitHub.

# Akuso assistant (optional in development)
ASSISTANT_ENABLED=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra
OPENAI_MODEL_PRIMARY=gpt-5.6-terra
OPENAI_MODEL_FAST=gpt-5.6-luna
OPENAI_MODEL_WRITING=gpt-5.6-terra
OPENAI_MODEL_REASONING=gpt-5.6-sol
# Publication safety. Visual uploads are held for review when the scanner or
# video decoder is unavailable; only completed safety checks may publish media.
MODERATION_ENABLED=true
MODERATION_PROVIDER=openai
MODERATION_MODEL=omni-moderation-latest
MODERATION_VISION_MODEL=gpt-5.4-mini
MODERATION_CONTEXTUAL_VISION_ENABLED=true
MODERATION_REQUEST_TIMEOUT_MS=15000
MODERATION_ADMIN_MEDIA_TIMEOUT_MS=10000
MODERATION_ADMIN_SCAN_DEADLINE_MS=90000
MODERATION_VIDEO_PROBE_TIMEOUT_MS=10000
MODERATION_VIDEO_EXTRACTION_TIMEOUT_MS=30000
MODERATION_EXPLICIT_BLOCK_THRESHOLD=0.92
MODERATION_CSAM_BLOCK_THRESHOLD=0.98
MODERATION_GORE_BLOCK_THRESHOLD=0.88
MODERATION_GORE_RESTRICT_THRESHOLD=0.64
MODERATION_ANIMAL_CRUELTY_BLOCK_THRESHOLD=0.86
MODERATION_REVIEW_THRESHOLD=0.45
AKUSO_REQUEST_TIMEOUT_MS=18000
AKUSO_MAX_INPUT_CHARS=2000
AKUSO_MAX_OUTPUT_TOKENS=2400
AKUSO_RATE_LIMIT_WINDOW_MS=900000
AKUSO_RATE_LIMIT_MAX=40
AKUSO_ENABLE_AUDIT_LOGS=true
AKUSO_ENABLE_STREAMING=false
AKUSO_ENABLE_WEB_SEARCH=true
ASSISTANT_ABUSE_WINDOW_MS=600000
ASSISTANT_THROTTLE_DURATION_MS=900000
ASSISTANT_ABUSE_THRESHOLD=4
ASSISTANT_MEMORY_RETENTION_DAYS=30
ASSISTANT_FEEDBACK_RETENTION_DAYS=90

# Paystack (required for payments)
# Keep the live backend value in the repo-root .env or deployment secrets.
# backend/.env is treated as a fallback for missing values only.
PAYSTACK_SECRET_KEY=sk_test_xxx
# Local/staging safety flag. Production always requires an sk_live_ key.
PAYSTACK_REQUIRE_LIVE_KEY=false
PAYSTACK_CALLBACK_URL=http://localhost:5173/payment/verify
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_CURRENCY=NGN
# Reclaim webhook attempts left in "received" after this processing lease expires.
PAYMENT_WEBHOOK_PROCESSING_LEASE_MS=120000

# Artist song/album tax policy. Disabled until a reviewed jurisdictional rate is configured.
# Tax is currently inclusive so the displayed checkout price does not change.
# Supported currencies are NGN and USD. Currency currently scopes applicability;
# ARTIST_MUSIC_TAX_JURISDICTION is an audit label, not buyer-location detection.
ARTIST_MUSIC_TAX_ENABLED=false
ARTIST_MUSIC_TAX_RATE_BPS=0
ARTIST_MUSIC_TAX_PRICE_MODE=inclusive
ARTIST_MUSIC_TAX_EFFECTIVE_AT=2026-07-14T23:00:00.000Z
ARTIST_MUSIC_TAX_CURRENCIES=NGN
ARTIST_MUSIC_TAX_JURISDICTION=

# Platform settlement account for Tengacion-owned funds
PLATFORM_SETTLEMENT_ACCOUNT_NAME=Stephen Mamman Kurah
PLATFORM_SETTLEMENT_BANK_NAME=Opay
PLATFORM_SETTLEMENT_ACCOUNT_NUMBER=8061201090

STRIPE_SECRET_KEY=sk_test_usd
STRIPE_PUBLISHABLE_KEY=pk_test_usd
STRIPE_WEBHOOK_SECRET=whsec_usd

# Optional cloudinary media upload
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional AWS S3 media upload
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=
AWS_S3_MEDIA_URL=https://s3.amazonaws.com/my-bucket

# Development mock for video uploads
USE_LOCAL_VIDEO_MOCK=true
LOCAL_VIDEO_MOCK_URL=https://storage.googleapis.com/free-videos/sample.mp4

# LiveKit (real-time streaming)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_HOST=https://livekit.example.com
LIVEKIT_WS_URL=wss://livekit.example.com

# Seed script defaults
SEED_CREATOR_EMAIL=creator@tengacion.dev
SEED_CREATOR_PASSWORD=Password123!
SEED_CREATOR_USERNAME=creator_mvp
SEED_CREATOR_DISPLAY_NAME=Tengacion Creator

# News ingestion and refresh
NEWS_AUTO_REFRESH_ENABLED=false
NEWS_RUN_REFRESH_ON_BOOT=true
NEWS_REFRESH_INTERVAL_MS=900000
NEWS_INGEST_LIMIT_PER_SOURCE=12
NEWS_CLUSTER_LIMIT=240
NEWS_SCORE_LIMIT=240

# Licensed / official news provider configuration
NEWS_REUTERS_BASE_URL=
NEWS_REUTERS_API_KEY=
NEWS_REUTERS_API_SECRET=

NEWS_AP_BASE_URL=
NEWS_AP_API_KEY=
NEWS_AP_API_SECRET=

NEWS_GUARDIAN_BASE_URL=
NEWS_GUARDIAN_API_KEY=
NEWS_GUARDIAN_API_SECRET=

NEWS_GDELT_BASE_URL=
NEWS_GDELT_API_KEY=
NEWS_GDELT_API_SECRET=

NEWS_CHANNELS_TV_RSS_URL=
NEWS_PREMIUM_TIMES_RSS_URL=
NEWS_LAGOS_TRAFFIC_RSS_URL=
NEWS_NEMA_RSS_URL=
NEWS_NIMET_RSS_URL=
NEWS_WHO_AFRICA_RSS_URL=
