NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/tengacion
JWT_SECRET=change_me_jwt_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
AUTH_CHALLENGE_SECRET=change_me_auth_challenge_secret
MEDIA_SIGNING_SECRET=change_me_media_signing_secret
FRONTEND_URL=http://localhost:5173
ALLOWED_FRONTEND_ORIGINS=http://localhost:5173
REQUIRE_EMAIL_OTP=false
CONTACT_EMAIL=stephen@tengacion.com
SUPPORT_EMAIL=stephen@tengacion.com
ADMIN_NOTIFICATION_EMAIL=stephen@tengacion.com
EMAIL_FROM=stephen@tengacion.com
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
# Legacy aliases are still accepted for existing deployments.
EMAIL_USER=
EMAIL_PASS=
# Production SMTP secrets must be configured in Render environment variables, not committed to GitHub.
ASSISTANT_ENABLED=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
# Publication safety. Install ffmpeg/ffprobe for video scans. Media is held for
# review whenever inspection is unavailable or incomplete.
MODERATION_ENABLED=true
MODERATION_PROVIDER=openai
MODERATION_MODEL=omni-moderation-latest
MODERATION_VISION_MODEL=gpt-5.4-mini
MODERATION_CONTEXTUAL_VISION_ENABLED=true
MODERATION_REQUEST_TIMEOUT_MS=15000
MODERATION_EXPLICIT_BLOCK_THRESHOLD=0.92
MODERATION_CSAM_BLOCK_THRESHOLD=0.98
MODERATION_GORE_BLOCK_THRESHOLD=0.88
MODERATION_GORE_RESTRICT_THRESHOLD=0.64
MODERATION_ANIMAL_CRUELTY_BLOCK_THRESHOLD=0.86
MODERATION_REVIEW_THRESHOLD=0.45
ASSISTANT_ABUSE_WINDOW_MS=600000
ASSISTANT_THROTTLE_DURATION_MS=900000
ASSISTANT_ABUSE_THRESHOLD=4
ASSISTANT_MEMORY_RETENTION_DAYS=30
ASSISTANT_FEEDBACK_RETENTION_DAYS=90

# Optional provider settings
PAYSTACK_SECRET_KEY=
PAYSTACK_CALLBACK_URL=http://localhost:5173/home
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_CURRENCY=NGN
# Reclaim webhook attempts left in "received" after this processing lease expires.
PAYMENT_WEBHOOK_PROCESSING_LEASE_MS=120000

# Artist song/album tax policy. Disabled until a reviewed jurisdictional rate is configured.
# Tax is currently inclusive so the displayed checkout price does not change.
# Supported currencies are NGN and USD. Currency currently scopes applicability;
# ARTIST_MUSIC_TAX_JURISDICTION is an audit label, not buyer-location detection.
ARTIST_MUSIC_TAX_ENABLED=false
ARTIST_MUSIC_TAX_RATE_BPS=0
ARTIST_MUSIC_TAX_PRICE_MODE=inclusive
ARTIST_MUSIC_TAX_EFFECTIVE_AT=2026-07-14T23:00:00.000Z
ARTIST_MUSIC_TAX_CURRENCIES=NGN
ARTIST_MUSIC_TAX_JURISDICTION=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional cloud storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=
AWS_S3_MEDIA_URL=

# Optional live streaming
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_HOST=
LIVEKIT_WS_URL=
