{
  "name": "tengacion",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "cross-env NODE_PATH=./node_modules node server.js",
    "dev": "nodemon server.js",
    "build": "npm run build:frontend",
    "build:frontend": "cd ../frontend && npm install --include=dev --no-save && npm run build",
    "seed:marketplace": "node scripts/seedMarketplace.js",
    "seed:news": "node scripts/seedNewsSampleData.js",
    "seed:admin": "node scripts/seedAdmin.js",
    "repair:user-media": "node scripts/repairUserMediaFields.js",
    "reset:admin-password": "node scripts/resetAdminPassword.js",
    "audit:legacy-media": "node scripts/reportLegacyMedia.js",
    "report:legacy-media": "node scripts/reportLegacyMedia.js",
    "cleanup:storage": "node scripts/storageCleanup.js",
    "eval:assistant": "cross-env NODE_PATH=./node_modules node scripts/runAssistantEvals.js",
    "test": "cross-env NODE_PATH=./node_modules jest --runInBand"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1026.0",
    "@aws-sdk/s3-request-presigner": "^3.1026.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "livekit-server-sdk": "^2.15.0",
    "mongoose": "^9.1.5",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^2.2.1",
    "nodemailer": "^8.0.5",
    "socket.io": "^4.8.3",
    "stripe": "^20.3.1",
    "streamifier": "^0.1.1",
    "tengacion": "file:..",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.3.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "overrides": {
    "lodash": "4.18.1",
    "@aws-sdk/xml-builder": {
      "fast-xml-parser": "5.5.10"
    },
    "express": {
      "path-to-regexp": "0.1.13"
    },
    "socket.io": {
      "socket.io-parser": "4.2.6"
    },
    "jest-util": {
      "picomatch": "4.0.4"
    },
    "micromatch": {
      "picomatch": "2.3.2"
    },
    "anymatch": {
      "picomatch": "2.3.2"
    },
    "readdirp": {
      "picomatch": "2.3.2"
    },
    "mongodb-memory-server-core": {
      "yauzl": "3.3.0"
    },
    "test-exclude": {
      "minimatch": {
        "brace-expansion": "1.1.13"
      }
    },
    "archiver-utils": {
      "glob": {
        "minimatch": "9.0.7",
        "brace-expansion": "5.0.5"
      },
      "readdir-glob": {
        "brace-expansion": "2.0.3"
      }
    }
  }
}
