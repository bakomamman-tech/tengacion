# Core
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/tengacion
JWT_SECRET=change_me_jwt_secret
MEDIA_SIGNING_SECRET=change_me_media_signing_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
AUTH_CHALLENGE_SECRET=change_me_auth_challenge_secret
APP_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
VITE_API_URL=/api
VITE_GIPHY_API_KEY=

# Auth / email OTP (optional)
REQUIRE_EMAIL_OTP=false
EMAIL_USER=
EMAIL_PASS=

# Akuso assistant (optional in development)
ASSISTANT_ENABLED=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_MODEL_PRIMARY=gpt-5.4-mini
OPENAI_MODEL_FAST=gpt-5.4-mini
OPENAI_MODEL_WRITING=gpt-5.4-mini
OPENAI_MODEL_REASONING=gpt-5.4
AKUSO_REQUEST_TIMEOUT_MS=12000
AKUSO_MAX_INPUT_CHARS=2000
AKUSO_MAX_OUTPUT_TOKENS=600
AKUSO_RATE_LIMIT_WINDOW_MS=900000
AKUSO_RATE_LIMIT_MAX=40
AKUSO_ENABLE_AUDIT_LOGS=true
AKUSO_ENABLE_STREAMING=false
ASSISTANT_ABUSE_WINDOW_MS=600000
ASSISTANT_THROTTLE_DURATION_MS=900000
ASSISTANT_ABUSE_THRESHOLD=4
ASSISTANT_MEMORY_RETENTION_DAYS=30
ASSISTANT_FEEDBACK_RETENTION_DAYS=90

# Paystack (required for payments)
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_CALLBACK_URL=http://localhost:5173/payment/verify
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_CURRENCY=NGN

STRIPE_SECRET_KEY=sk_test_usd
STRIPE_PUBLISHABLE_KEY=pk_test_usd
STRIPE_WEBHOOK_SECRET=whsec_usd

# Optional cloudinary media upload
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional AWS S3 media upload
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=
AWS_S3_MEDIA_URL=https://s3.amazonaws.com/my-bucket

# Development mock for video uploads
USE_LOCAL_VIDEO_MOCK=true
LOCAL_VIDEO_MOCK_URL=https://storage.googleapis.com/free-videos/sample.mp4

# LiveKit (real-time streaming)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_HOST=https://livekit.example.com
LIVEKIT_WS_URL=wss://livekit.example.com

# Seed script defaults
SEED_CREATOR_EMAIL=creator@tengacion.dev
SEED_CREATOR_PASSWORD=Password123!
SEED_CREATOR_USERNAME=creator_mvp
SEED_CREATOR_DISPLAY_NAME=Tengacion Creator

# News ingestion and refresh
NEWS_AUTO_REFRESH_ENABLED=false
NEWS_RUN_REFRESH_ON_BOOT=true
NEWS_REFRESH_INTERVAL_MS=900000
NEWS_INGEST_LIMIT_PER_SOURCE=12
NEWS_CLUSTER_LIMIT=240
NEWS_SCORE_LIMIT=240

# Licensed / official news provider configuration
NEWS_REUTERS_BASE_URL=
NEWS_REUTERS_API_KEY=
NEWS_REUTERS_API_SECRET=

NEWS_AP_BASE_URL=
NEWS_AP_API_KEY=
NEWS_AP_API_SECRET=

NEWS_GUARDIAN_BASE_URL=
NEWS_GUARDIAN_API_KEY=
NEWS_GUARDIAN_API_SECRET=

NEWS_GDELT_BASE_URL=
NEWS_GDELT_API_KEY=
NEWS_GDELT_API_SECRET=

NEWS_CHANNELS_TV_RSS_URL=
NEWS_PREMIUM_TIMES_RSS_URL=
NEWS_LAGOS_TRAFFIC_RSS_URL=
NEWS_NEMA_RSS_URL=
NEWS_NIMET_RSS_URL=
NEWS_WHO_AFRICA_RSS_URL=
